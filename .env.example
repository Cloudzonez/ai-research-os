# ============================================
# AI Research OS - Environment Configuration
# ============================================

# ============================================
# Core Application Settings
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# For local: mongodb://localhost:27017/ai_research
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai_research
MONGO_URI=mongodb://localhost:27017/ai_research

# ============================================
# Authentication & Security
# ============================================
# Secret key for JWT token signing (change in production!)
AUTH_SECRET=your-secret-key-change-in-production

# ============================================
# AI Model Configuration
# ============================================
# DeepSeek API (Required for chat, query parsing, metadata extraction)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Default model for general tasks
MODEL_NAME=deepseek-v4-pro

# Task-specific model routing (optional, defaults to MODEL_NAME)
CHAT_MODEL=deepseek-v4-pro
CODE_MODEL=deepseek-v4-pro
CRAWLER_MODEL=deepseek-v4-pro
SUMMARY_MODEL=deepseek-v4-pro

# ============================================
# Discovery & Search - Embedding Service
# ============================================
# OpenAI API (Required for semantic search and embeddings)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-large

# ============================================
# Discovery & Search - External APIs
# ============================================
# OpenAlex API (Free, no key required, but email recommended for polite pool)
OPENALEX_EMAIL=your-email@example.com

# Semantic Scholar API (Optional, increases rate limits)
# Free tier: 100 requests per 5 minutes
# With API key: 5,000 requests per 5 minutes
SEMANTIC_SCHOLAR_API_KEY=

# PubMed E-utilities (Optional, increases rate limits)
# Free tier: 3 requests/second
# With API key: 10 requests/second
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# CORE API (Required for CORE search)
# Free tier: 10,000 requests/month
# Get key at: https://core.ac.uk/services/api
CORE_API_KEY=

# PhilPapers API (Free, no key required)
# Comprehensive philosophy research index
# No configuration needed

# SSRN API (Optional, requires registration)
# Social Science Research Network
# Contact SSRN for API access
SSRN_API_KEY=

# ============================================
# Discovery & Search - Caching
# ============================================
# Redis connection URL (Required for search caching)
# For local: redis://localhost:6379
# For cloud: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (default: 300 = 5 minutes)
SEARCH_CACHE_TTL=300

# ============================================
# Discovery & Search - Performance Tuning
# ============================================
# Maximum concurrent sources to query in parallel
MAX_CONCURRENT_SOURCES=5

# Timeout per search source in milliseconds
SEARCH_TIMEOUT=15000

# Title similarity threshold for deduplication (0-1, default: 0.95)
TITLE_SIMILARITY_THRESHOLD=0.95

# Embedding similarity threshold for deduplication (0-1, default: 0.92)
EMBEDDING_SIMILARITY_THRESHOLD=0.92

# ============================================
# File Storage
# ============================================
# Directory for uploaded files (PDFs, etc.)
STORAGE_PATH=./uploads

# ============================================
# Grey Literature & Patents
# ============================================
# BASE (Bielefeld Academic Search Engine) - Free, no key required
# 240M+ documents from 8,000+ sources
# No configuration needed

# OpenGrey - European grey literature
# Free, no key required
# No configuration needed

# USPTO (United States Patent and Trademark Office)
# Free, no key required
# No configuration needed

# ============================================
# Google Scholar Integration
# ============================================
# Google Scholar proxies (comma-separated list)
# Format: http://host:port or socks5://host:port or http://user:pass@host:port
# Example: http://proxy1.com:8080,http://proxy2.com:8080,socks5://proxy3.com:1080
# Leave empty to use direct connection (may get rate limited)
GOOGLE_SCHOLAR_PROXIES=

# Note: Google Scholar has aggressive rate limiting
# - Without proxies: ~1 request per 10 seconds recommended
# - With proxies: Can increase throughput but still be conservative
# - Consider using SerpAPI as alternative (see below)

# ============================================
# Optional: Paid API Services
# ============================================
# SerpAPI for Google Scholar (Optional, paid service)
# ~$50/month for 5,000 searches
# More reliable than scraping, no rate limit issues
# SERPAPI_KEY=

# Lens.org for patent search (Optional, free academic tier available)
# LENS_API_KEY=

# ============================================
# Development & Debugging
# ============================================
# Enable verbose logging
# DEBUG=search:*

# Skip cache for testing
# SKIP_CACHE=true

# ============================================
# Production Deployment
# ============================================
# For production, also consider:
# - Use strong AUTH_SECRET (generate with: openssl rand -base64 32)
# - Use MongoDB Atlas with proper authentication
# - Use managed Redis (AWS ElastiCache, Redis Cloud, etc.)
# - Set NODE_ENV=production
# - Configure proper CORS origins
# - Set up SSL/TLS certificates
# - Configure rate limiting
# - Set up monitoring and alerting

# ============================================
# Quick Start Checklist
# ============================================
# Required for basic functionality:
# ✅ DEEPSEEK_API_KEY - Get from https://deepseek.com
# ✅ MONGO_URI - Local or Atlas connection string
# ✅ AUTH_SECRET - Generate a secure random string
#
# Required for Discovery & Search:
# ✅ OPENAI_API_KEY - Get from https://platform.openai.com
# ✅ REDIS_URL - Local Redis or cloud service
# ✅ OPENALEX_EMAIL - Your email for API polite pool
#
# Optional but recommended:
# ⭐ SEMANTIC_SCHOLAR_API_KEY - Increases rate limits (5K vs 100 req/5min)
# ⭐ PUBMED_API_KEY - Increases rate limits (10 vs 3 req/sec)
# ⭐ CORE_API_KEY - Access to 200M+ open access papers (10K req/month free)
#
# Optional for specialized searches:
# 📚 SSRN_API_KEY - Social science preprints (requires registration)
# 💰 SERPAPI_KEY - For Google Scholar access (~$50/month)
# 💰 LENS_API_KEY - For patent search (free academic tier available)

# ============================================
# Cost Estimates (Monthly)
# ============================================
# MongoDB Atlas M10: $57/month
# OpenAI Embeddings: ~$0.65 one-time + $0.12/month
# Redis (self-hosted): $0
# DeepSeek API: Pay-as-you-go
# Semantic Scholar: Free
# OpenAlex: Free
# arXiv: Free
# ============================================
# Total: ~$58/month for 10K papers, 100 queries/day
# ============================================