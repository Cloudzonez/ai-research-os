# =============================================================================
# Academic Radar — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=development
STORAGE_PATH=./uploads

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/ai_research

# --- Auth ---
AUTH_SECRET=dev-secret-change-in-production

# --- DeepSeek AI ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-v4-pro

# Task-specific model overrides (optional — fall back to MODEL_NAME)
CHAT_MODEL=deepseek-v4-pro
CODE_MODEL=deepseek-v4-pro
CRAWLER_MODEL=deepseek-v4-pro
SUMMARY_MODEL=deepseek-v4-pro

# --- Alternate AI providers (optional) ---
# ANTHROPIC_API_KEY=

# --- Academic API keys (optional — rate limits vary without these) ---
OPENALEX_API_KEY=
CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=
UNPAYWALL_EMAIL=

# --- GitHub ---
# GITHUB_TOKEN=

# --- Logging ---
LOG_LEVEL=debug
DEV_VERBOSE_LOGGING=1
PERSIST_LOGS=1
LOG_MEMORY_LIMIT=1000

# --- Proxy bypass (required behind a corporate proxy) ---
NO_PROXY=127.0.0.1,localhost,::1
no_proxy=127.0.0.1,localhost,::1
